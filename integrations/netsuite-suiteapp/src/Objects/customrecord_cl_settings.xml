<customrecordtype scriptid="customrecord_cl_settings">
    <accesstype>NORESTRICTION</accesstype>
    <allowattachments>F</allowattachments>
    <allowinlinedeletion>F</allowinlinedeletion>
    <allowinlineediting>T</allowinlineediting>
    <allowinlinenewrecords>F</allowinlinenewrecords>
    <allowmobileaccess>F</allowmobileaccess>
    <allownumberingoverride>F</allownumberingoverride>
    <allowquickadd>F</allowquickadd>
    <allowquicksearch>F</allowquicksearch>
    <description>Single-row tenant config for the Solden SuiteApp: API base URL + workspace base URL + NetSuite API Secret reference used to mint short-lived JWTs for the panel iframe.</description>
    <enabledle>F</enabledle>
    <enableemailmerge>F</enableemailmerge>
    <enablekeywords>F</enablekeywords>
    <enablemailmerge>F</enablemailmerge>
    <enablenametranslation>F</enablenametranslation>
    <enablenumbering>F</enablenumbering>
    <enableoptimisticlocking>T</enableoptimisticlocking>
    <enablesystemnotes>T</enablesystemnotes>
    <hierarchical>F</hierarchical>
    <iconbuiltin>T</iconbuiltin>
    <includeinsearchmenu>F</includeinsearchmenu>
    <includename>T</includename>
    <isinactive>F</isinactive>
    <isordered>F</isordered>
    <recordname>Solden Settings</recordname>
    <showcreationdate>F</showcreationdate>
    <showcreationdateonlist>F</showcreationdateonlist>
    <showid>T</showid>
    <showlastmodified>F</showlastmodified>
    <showlastmodifiedonlist>F</showlastmodifiedonlist>
    <shownotes>F</shownotes>
    <showowner>F</showowner>
    <showownerallowchange>F</showownerallowchange>
    <showowneronlist>F</showowneronlist>
    <customrecordcustomfields>
        <customrecordcustomfield scriptid="custrecord_cl_api_base">
            <fieldtype>FREEFORMTEXT</fieldtype>
            <label>Solden API Base URL</label>
            <defaultvalue>https://api.soldenai.com</defaultvalue>
            <displaytype>NORMAL</displaytype>
            <ismandatory>T</ismandatory>
            <maxlength>255</maxlength>
            <description>Base URL for Solden API. Defaults to api.soldenai.com; override only for staging or self-hosted deployments.</description>
        </customrecordcustomfield>
        <customrecordcustomfield scriptid="custrecord_cl_app_base">
            <fieldtype>FREEFORMTEXT</fieldtype>
            <label>Solden Workspace Base URL</label>
            <defaultvalue>https://workspace.soldenai.com</defaultvalue>
            <displaytype>NORMAL</displaytype>
            <ismandatory>T</ismandatory>
            <maxlength>255</maxlength>
            <description>Base URL for the Solden workspace deep link opened from the NetSuite panel.</description>
        </customrecordcustomfield>
        <customrecordcustomfield scriptid="custrecord_cl_bundle_secret">
            <fieldtype>FREEFORMTEXT</fieldtype>
            <label>Solden Bundle Secret Reference</label>
            <displaytype>NORMAL</displaytype>
            <ismandatory>T</ismandatory>
            <maxlength>255</maxlength>
            <description>NetSuite API Secret script ID or SecretKey GUID for the shared HMAC secret provisioned during onboarding. The secret value is stored in NetSuite API Secrets and in Solden's encrypted `erp_connections.credentials.webhook_secret` for verification.</description>
        </customrecordcustomfield>
        <customrecordcustomfield scriptid="custrecord_cl_org_id">
            <fieldtype>FREEFORMTEXT</fieldtype>
            <label>Solden Organization ID</label>
            <displaytype>NORMAL</displaytype>
            <ismandatory>T</ismandatory>
            <maxlength>128</maxlength>
            <description>Tenant's Solden org_id. Used by outbound vendor-bill webhooks to address the correct tenant on the Solden side (URL path component). Provisioned during onboarding.</description>
        </customrecordcustomfield>
    </customrecordcustomfields>
</customrecordtype>
