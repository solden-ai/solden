<usereventscript scriptid="customscript_cl_ue_panel">
    <description>Renders Solden panel subtab on Vendor Bill records (Phase 1-3 scaffold).</description>
    <isinactive>F</isinactive>
    <name>Solden — Vendor Bill Panel</name>
    <notifyadmins>F</notifyadmins>
    <notifyemails></notifyemails>
    <notifygroup></notifygroup>
    <notifyowner>T</notifyowner>
    <notifyuser>F</notifyuser>
    <scriptfile>[/SuiteApps/com.clearledgr.suiteapp/ue_clearledgr_panel.js]</scriptfile>
    <scriptdeployments>
        <scriptdeployment scriptid="customdeploy_cl_ue_panel">
            <allemployees>T</allemployees>
            <allroles>T</allroles>
            <allpartners>F</allpartners>
            <isdeployed>T</isdeployed>
            <loglevel>DEBUG</loglevel>
            <recordtype>VENDORBILL</recordtype>
            <runasrole>ADMINISTRATOR</runasrole>
            <status>RELEASED</status>
            <title>Solden — Vendor Bill Panel · Deployment</title>
            <eventtype></eventtype>
            <!-- No executioncontext restriction: beforeLoad needs USERINTERFACE
                 to render the panel, but afterSubmit must fire on EVERY save
                 path (CSV import, RESTlet, vendor portal API, SuiteFlow,
                 manual UI save) so ERP-native bill creates reach Solden. -->
        </scriptdeployment>
    </scriptdeployments>
</usereventscript>
