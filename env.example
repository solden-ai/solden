# Solden Environment Variables
# Copy to .env and fill in your values

# ── Core Configuration ───────────────────────────────────────────────
# Environment name: dev | staging | production (controls security defaults)
ENV=dev
# Required. In production the app refuses to start if this is unset.
SOLDEN_SECRET_KEY=your-secret-key-change-in-production
# Postgres ONLY. There is no SQLite fallback — the DB layer raises at
# startup if DATABASE_URL is missing or non-Postgres. For local dev point
# at a local Postgres; on Railway use the managed Postgres URL.
DATABASE_URL=postgresql://user:password@localhost:5432/solden
# Postgres connection timeout in seconds (default: 2)
DB_CONNECT_TIMEOUT=2
# Postgres connection pool max size (default: 10)
DB_POOL_MAX_SIZE=10
REDIS_URL=redis://localhost:6379/0
# Internal/backend base URL used by local surfaces and default callbacks.
API_BASE_URL=http://127.0.0.1:8010
# Public HTTPS base URL used for Slack/Gmail OAuth redirects and external links.
# On Railway, set this to your public app domain, for example:
# https://solden-api-production.up.railway.app
APP_BASE_URL=http://127.0.0.1:8010
# Override Slack OAuth redirect explicitly if needed. When omitted, Solden
# derives it from APP_BASE_URL.
SLACK_REDIRECT_URI=
# Process role:
# - all: single process runs the API AND the background loops
#        (monitoring sweep, daily digests, period-close, GRN polling,
#        vendor sync). Simplest for local dev or a small deploy.
# - web: API only — does NOT run the in-process background loops.
# - worker: background loops only.
# NOTE: if you split web + worker, the proactive monitoring sweep now runs
# on the Celery beat schedule, so alerting is no longer blind in that
# topology. The in-process loop above only fires for role=all.
SOLDEN_PROCESS_ROLE=all
# Base URL for frontend redirects (default: /)
FRONTEND_URL=/
# Public base URL for vendor onboarding callbacks.
SOLDEN_PORTAL_BASE_URL=https://onboard.soldenai.com
# Default org ID when none is specified (default: default)
DEFAULT_ORGANIZATION_ID=default
# Optional API key for service-to-service auth
API_KEY=

# ── ERP OAuth - QuickBooks ────────────────────────────────────────────
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=https://your-domain.com/oauth/quickbooks/callback

# ── ERP OAuth - Xero ─────────────────────────────────────────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://your-domain.com/oauth/xero/callback

# ── Payment Gateways ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
PAYSTACK_SECRET_KEY=sk_live_...
FLUTTERWAVE_SECRET_KEY=FLWSECK_...

# ── AI / LLM ─────────────────────────────────────────────────────────
# Effectively required: invoice extraction + agent reasoning run through
# Claude. In production the app fails fast at startup if this is unset
# (a missing key otherwise passes health checks and only breaks on the
# first real invoice).
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=sk-...
# Claude model for general AP reasoning (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6
# Claude model for invoice data extraction (default: claude-haiku-4-5-20251001)
ANTHROPIC_EXTRACTION_MODEL=claude-haiku-4-5-20251001
# Primary LLM provider: anthropic | mistral (default: anthropic)
LLM_PRIMARY_PROVIDER=anthropic
# LLM request timeout in seconds (default: 45 for extraction, 30 for decisions)
LLM_TIMEOUT_SECONDS=45
# Optional Mistral API key and model
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# ── Notifications / Slack ─────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_SIGNING_SECRET=your-slack-signing-secret
# Slack Bot token for app-based notifications (set during OAuth install)
SLACK_BOT_TOKEN=xoxb-...
# Slack OAuth app credentials (for workspace install flow)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Preferred channel for approval cards (default: none — falls back to SLACK_DEFAULT_CHANNEL)
SLACK_APPROVAL_CHANNEL=
# Fallback channel for general notifications (default: #finance)
SLACK_DEFAULT_CHANNEL=#finance
# Slack integration mode: shared | per_org (default: shared)
SLACK_INTEGRATION_MODE=shared
# Allow fallback to shared Slack token when per-org is missing (default: true)
SLACK_ALLOW_SHARED_FALLBACK=true
# Cooldown between Slack escalation notifications in seconds (default: 1800)
SLACK_ESCALATION_COOLDOWN_SECONDS=1800
# Channel for ops/SRE alerts from AP health checks (default: #ap-ops-alerts)
AP_OPS_SLACK_CHANNEL=#ap-ops-alerts

# ── Notifications / Teams ────────────────────────────────────────────
TEAMS_APP_ID=your-teams-bot-app-id
TEAMS_APP_PASSWORD=your-teams-bot-app-password
# Teams app secret (alternative credential name used by some Teams endpoints)
TEAMS_APP_SECRET=
# Teams Bot Framework service URL override (default: auto-detected)
TEAMS_SERVICE_URL=
# Teams approval webhook URL for proactive card delivery
TEAMS_APPROVAL_WEBHOOK_URL=

# ── AP Runtime / Orchestration ────────────────────────────────────────
# The agent runtime is Celery + Redis Streams + Postgres (see §11.2.1).
# There is no Temporal dependency — the legacy AP_TEMPORAL_* flags were
# removed in favour of this stack.
# AP-v1 strict surface profile:
# - In production/staging, strict mode is enforced by default.
# - Setting AP_V1_STRICT_SURFACES=false in production is ignored.
# - Strict mode blocks legacy/non-canonical route families (email/audit/payments/etc).
AP_V1_STRICT_SURFACES=true
SOLDEN_ENABLE_LEGACY_SURFACES=false
# Production-only escape hatch; keep false for AP v1.
AP_V1_ALLOW_LEGACY_SURFACES_IN_PRODUCTION=false
AP_AGENT_AUTONOMOUS_RETRY_ENABLED=true
AP_AGENT_POST_PROCESS_DURABLE_ENABLED=true
# Safe default for pilot/staging/testing: keep non-durable retry disabled until durable retry exists.
# Enable (`true`) only for local exploratory/dev behavior testing.
AP_AGENT_NON_DURABLE_RETRY_ALLOWED=false
AP_AGENT_POST_PROCESS_MAX_ATTEMPTS=3
AP_AGENT_POST_PROCESS_BACKOFF_SECONDS=5,15,45

# Browser runner trust policy for /api/agent/sessions/{id}/results|complete
# Options: authenticated | api_or_admin | api_only
AP_BROWSER_RUNNER_TRUST_MODE=api_or_admin

# ── Gmail Autopilot ───────────────────────────────────────────────────
# Enable Gmail autopilot processing (default: true)
GMAIL_AUTOPILOT_ENABLED=true
# Autopilot mode: poll | watch | both (default: both)
GMAIL_AUTOPILOT_MODE=both
# Polling interval in seconds (default: 300)
GMAIL_POLL_INTERVAL_SEC=300
# Max messages per poll cycle (default: 50)
GMAIL_POLL_MAX_RESULTS=50
# Hours of history to seed on first poll (default: 24)
GMAIL_POLL_SEED_HOURS=24
# Hours between Gmail watch renewal (default: 12)
GMAIL_WATCH_REFRESH_HOURS=12
# Custom Gmail search query override (default: auto-generated)
GMAIL_POLL_QUERY=
# Pub/Sub topic for Gmail push notifications
GMAIL_PUBSUB_TOPIC=projects/solden/topics/gmail-push
# Gmail push verifier for public /gmail/push callback.
GMAIL_PUSH_SHARED_SECRET=
# Keep false in production; only true for controlled local/dev testing.
GMAIL_PUSH_ALLOW_UNVERIFIED_IN_PROD=false

# Cloudflare Tunnel (for webhook testing)
CLOUDFLARE_TUNNEL_TOKEN=

# ── Gmail / Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Preferred Gmail integration callback; legacy GOOGLE_REDIRECT_URI is still read.
GOOGLE_GMAIL_REDIRECT_URI=http://localhost:8010/gmail/callback
GOOGLE_REDIRECT_URI=http://localhost:8010/gmail/callback
# OAuth state TTL (seconds) for Gmail OAuth callback validation.
GMAIL_OAUTH_STATE_MAX_AGE_SECONDS=900
# Google auth code TTL in seconds (default: 180)
GOOGLE_AUTH_CODE_TTL_SECONDS=180

# Outlook / Microsoft Graph OAuth (for autonomous Outlook email processing)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8010/outlook/callback
MICROSOFT_TENANT_ID=common
OUTLOOK_WEBHOOK_SECRET=
OUTLOOK_WEBHOOK_URL=https://your-domain.com/outlook/webhook
OUTLOOK_CONNECT_REDIRECT=/

# Sentry error tracking (opt-in)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Monitoring alert channels (comma-separated: slack,webhook,log)
MONITOR_ALERT_CHANNELS=slack,log
# Override thresholds (optional)
# MONITOR_THRESHOLD_DEAD_LETTER_MAX=5
# MONITOR_THRESHOLD_POSTING_FAILURE_RATE_PCT=20
# MONITOR_THRESHOLD_AUTH_FAILURE_MAX=3
# MONITOR_THRESHOLD_STALE_POLL_HOURS=2
# MONITOR_THRESHOLD_OVERDUE_INVOICES_MAX=20

# Max seconds for a single agent planning task (default: 600)
AGENT_MAX_TASK_SECONDS=600
# Minutes before an AP workflow is considered stuck (default: 120)
AP_WORKFLOW_STUCK_MINUTES=120
# Enable browser agent for ERP follow-on actions (default: true)
AP_BROWSER_AGENT_ENABLED=true
# TTL for ERP follow-on browser fallback sessions in seconds (default: 1800)
ERP_FOLLOW_ON_BROWSER_FALLBACK_TTL_SECONDS=1800
# Token encryption key (REQUIRED in production — used for Fernet-encrypting OAuth tokens at rest)
TOKEN_ENCRYPTION_KEY=
# Optional on-disk fallback path for the token key (default: .solden_token_key)
TOKEN_ENCRYPTION_KEY_FILE=.solden_token_key

# ERP OAuth - NetSuite
NETSUITE_ACCOUNT_ID=
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=

# ERP - SAP
SAP_TLS_CA_BUNDLE_PATH=

# ── Rate Limiting ─────────────────────────────────────────────────────
# Enable rate limiting (default: true)
RATE_LIMIT_ENABLED=true
# Requests per window (default: 100)
RATE_LIMIT_REQUESTS=100
# Rate limit window in seconds (default: 60)
RATE_LIMIT_WINDOW=60
# Allow in-memory rate limiter in production when Redis is unavailable (default: false)
AP_V1_ALLOW_IN_MEMORY_RATE_LIMIT_IN_PRODUCTION=false

# ── Logging / Monitoring ─────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
# Emit structured JSON logs (default: false)
USE_JSON_LOGS=false

# ── Onboarding / Plaid ───────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
# Plaid environment: sandbox | development | production (default: sandbox)
PLAID_ENV=sandbox

# ── Workspace / Admin ────────────────────────────────────────────────
# Enable workspace shell admin panel (default: true)
WORKSPACE_SHELL_ENABLED=true
# Cookie domain for workspace sessions (default: auto-detected)
WORKSPACE_SESSION_COOKIE_DOMAIN=

# ── Finance Lead / Escalation ────────────────────────────────────────
# Email for escalation notifications (checked in order)
SOLDEN_FINANCE_LEAD_EMAIL=
FINANCE_LEAD_EMAIL=
# Invite URL shown in Slack task notification buttons
SOLDEN_INVITE_URL=

# ── Data Export ───────────────────────────────────────────────────────
# Path to export reviewed extraction data for fine-tuning (default: disabled)
SOLDEN_REVIEWED_EXTRACTION_EXPORT_PATH=
