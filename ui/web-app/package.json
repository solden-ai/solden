{
  "name": "solden-web-app",
  "version": "0.1.0",
  "description": "workspace.soldenai.com — work-in-progress control center. Renders live Solden records; Gmail/Slack/Teams/ERP are companion surfaces.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173",
