    "start:prod": "npm run build && node server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.21.2",
    "htm": "^3.1.1",
    "http-proxy-middleware": "^3.0.5",
    "preact": "^10.29.2",
    "wouter-preact": "^3.10.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.0",
    "@testing-library/preact": "^3.2.4",
    "happy-dom": "^20.10.2",
    "vite": "^7.1.0",
    "vitest": "^3.2.4"
  }
}
