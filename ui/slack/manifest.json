{
  "display_information": {
    "name": "Solden",
    "description": "Finance work memory — approvals, exceptions, and next actions",
    "background_color": "#0a1628",
    "long_description": "Solden keeps finance work in progress together across Gmail, Slack, Teams, and ERP. In Slack, teams review AP exceptions, approve or reject invoices, and keep proof attached without leaving chat."
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "Solden",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/solden",
        "url": "https://YOUR_DOMAIN/slack/commands",
        "description": "Run Solden commands",
        "usage_hint": "[status | run | exceptions | tasks | help]",
        "should_escape": false
      },
      {
        "command": "/reconcile",
        "url": "https://YOUR_DOMAIN/slack/commands",
        "description": "Run AP queue health check (legacy command name)",
        "usage_hint": "",
        "should_escape": false
      },
      {
        "command": "/categorize",
        "url": "https://YOUR_DOMAIN/slack/commands",
        "description": "Review AP exception routing suggestions (legacy command name)",
        "usage_hint": "[review | patterns | learn | exceptions]",
        "should_escape": false
      }
    ],
    "shortcuts": [
      {
        "name": "Create Finance Task",
        "type": "message",
        "callback_id": "create_task_from_message",
        "description": "Turn this message into a Solden task"
      },
      {
        "name": "Run AP Health Check",
        "type": "global",
        "callback_id": "run_reconciliation",
        "description": "Run AP queue/exception health on your connected workspace"
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:read",
        "chat:write",
        "commands",
        "groups:read",
        "im:write",
        "users:read",
        "users:read.email"
      ],
      "user": [
      ]
    },
    "redirect_urls": [
      "https://YOUR_DOMAIN/slack/oauth/callback"
    ]
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://YOUR_DOMAIN/slack/events",
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://YOUR_DOMAIN/slack/interactions"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
