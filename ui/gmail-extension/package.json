{
  "name": "solden-gmail-extension",
  "version": "0.2.0",
  "description": "Finance execution agents embedded in Gmail — AP workflows today, more coming",
  "type": "module",
  "main": "background.js",
  "scripts": {
    "start": "bun build ./src/inboxsdk-layer.js ./node_modules/@inboxsdk/core/pageWorld.js --target=browser --format=iife --sourcemap=none --outdir dist --entry-naming=[name].js --watch",
    "build": "node scripts/build-extension.cjs --config webpack.dev.cjs --verify",
    "build:prod": "node scripts/build-extension.cjs --config webpack.prod.cjs",
    "verify:bundle": "node scripts/verify-bundle-parity.cjs",
    "verify:bundle:strict": "node scripts/verify-bundle-parity.cjs --check-git-clean",
    "test": "node --test tests/*.test.cjs",
    "test:components": "node --test --test-concurrency=1 src/components/*.test.js src/utils/*.test.js",
    "test:integration": "node --test tests/inboxsdk-layer.integration.test.cjs tests/inboxsdk-layer-ui.test.cjs tests/bundle-contract.test.cjs tests/queue-manager.auth.test.cjs tests/queue-manager.agent-intents.test.cjs && npm run verify:bundle",
    "test:browser-harness": "RUN_GMAIL_BROWSER_HARNESS=1 node --test tests/inboxsdk-layer.browser-harness.test.cjs",
    "test:browser-harness:ci": "RUN_GMAIL_BROWSER_HARNESS=1 GMAIL_BROWSER_HARNESS_REQUIRE_BROWSER=1 node --test tests/inboxsdk-layer.browser-harness.test.cjs",
    "test:e2e-smoke": "RUN_GMAIL_E2E=1 node --test tests/inboxsdk-layer.e2e-smoke.test.cjs",
    "test:e2e-auth": "RUN_GMAIL_E2E=1 GMAIL_E2E_ASSERT_AUTH=1 node --test tests/inboxsdk-layer.e2e-smoke.test.cjs",
    "test:e2e-runner:preflight": "node scripts/gmail-e2e-runner-preflight.cjs",
    "test:e2e-auth:evidence": "node scripts/run-gmail-e2e-auth-with-evidence.cjs",
    "test:e2e-evidence:validate": "node scripts/gmail-e2e-evidence.cjs",
    "evidence:ui-hardening": "node scripts/capture-ui-hardening-evidence.cjs"
  },
  "keywords": [
    "gmail",
    "chrome-extension",
    "invoice",
    "finance",
    "automation"
  ],
  "author": "Solden",
  "license": "ISC",
  "dependencies": {
    "@inboxsdk/core": "^2.2.11",
    "htm": "^3.1.1",
    "preact": "^10.29.0"
  },
  "devDependencies": {
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "acorn": "^8.15.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^27.0.1",
    "vitest": "^4.1.5"
  }
}
