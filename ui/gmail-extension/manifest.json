{
  "manifest_version": 3,
  "name": "Solden",
  "version": "0.4.2",
  "version_name": "0.4.2",
  "description": "Solden in your inbox — see your back-office runtime act on invoices and approvals from inside Gmail.",
  "key": "",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "identity",
    "identity.email",
    "notifications",
    "alarms"
  ],
  "oauth2": {
    "client_id": "333271407440-j42m0b6sh4j42bvlkr0vko7l058uf3ja.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.labels",
      "https://www.googleapis.com/auth/gmail.modify",
      "https://www.googleapis.com/auth/gmail.readonly",
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/calendar.readonly"
    ]
  },
  "host_permissions": [
    "https://mail.google.com/*",
    "https://gmail.google.com/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://api.soldenai.com/*",
    "https://staging-api.soldenai.com/*",
    "http://localhost:8010/*",
    "http://127.0.0.1:8010/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://gmail.google.com/*"
      ],
      "js": [
        "route-capture.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://mail.google.com/*",
        "https://gmail.google.com/*"
      ],
      "js": [
        "config.js",
        "dist/inboxsdk-layer.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png",
        "dist/pageWorld.js",
        "dist/inboxsdk-layer.js"
      ],
      "matches": [
        "https://mail.google.com/*",
        "https://gmail.google.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "Solden"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
